# ================= НАСТРОЙКИ ПЕРСОНАЖЕЙ И ФОНОВ =================
define alina = Character("Алина", color="#e27d60")
define sergey = Character("Сергей", color="#41b3a3")

# Фоны (положи файлы фото1.jpg, фото2.jpg... в папку game/images/)
image фото1:
    "самолет1"
    zoom 2.0
image фото2:
    "шалаш в лесу"
    zoom 2.0
image фото3:
    "утро в лагере"
    zoom 2.0
image фото4:
    "река финал"
    zoom 1.6
image фото5:
    "берег"
    zoom 1.6
image фото6:
    "берег 2"
    zoom 1.6
image фото9:
    "шалаш с костром"
    zoom 2.0
# Спрайты (уменьшаем масштаб)
image мужчина = Transform("мужчина.png", zoom=0.5)
image женщина = Transform("женщина.png", zoom=0.5)

# ================= ПОЗИЦИИ ПЕРСОНАЖЕЙ =================
# Эти трансформации поднимают персонажей выше текста (yalign 0.35)
# xalign 0.25 - слева, xalign 0.75 - справа
transform high_left:
    xalign 0
    yalign 0.53

transform high_right:
    xalign 0.9999999
    yalign 0.53

transform high_center:
    xalign 0.5
    yalign 0.53

# ================= НАЧАЛО ИГРЫ =================
label start:
    jump scene1

# ================= СЦЕНА 1: КРУШЕНИЕ =================
label scene1:
    scene фото1 with fade
    
    play sound "crash_sound.mp3" volume 0.7
    "{i}(Гул самолёта, тревожные крики. Резкий толчок, звук рвущегося металла. Затем - тишина, прерываемая треском огня и стонами.){/i}"
    
    # Алина приходит в себя
    show женщина at high_right with dissolve
    alina "Что… что случилось?.."
    
    # Алина отвечает
    alina "Эй!.. Вам… вам помочь?"
    
    # Сергей отвечает
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Да, если можете. Меня придавило."
    
    # Нарратор (действия)
    hide мужчина
    "{i}(Алина  подходит ближе и помогает отодвинуть обломок. Мужчина благодарно сжимает её руку.){/i}"
    
    # Диалог
    show женщина at high_right with dissolve
    alina "Вы… вы из экипажа?"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Нет. Инженер. Но базовую подготовку проходил."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Что нам делать?.. Где мы?"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Пока - спасаться. Потом разберёмся."
    
    # Знакомство
    show мужчина at high_center with dissolve
    sergey "Меня зовут Сергей."
    
    hide мужчина
    show женщина at high_center with dissolve
    alina "А я Алина."
    
    hide женщина
    show мужчина at high_center with dissolve
    sergey "Давай выживать, Алина."
    hide мужчина

    stop sound
    menu choice1:
        "Остаться и поискать припасы среди обломков":
            jump scene1_main
        "Уходить сразу, пока не стемнело":
            jump scene1_fail

# --- ОСНОВНОЙ ПУТЬ (СЦЕНА 1) ---
label scene1_main:
    show женщина at high_right with dissolve
    alina "Ты прав. Нам нужно хоть что-то взять."
    
    hide женщина
    "{i}(Они обыскивают обломки. Алина находит рваный рюкзак.){/i}"
    
    show женщина at high_right with dissolve
    alina "Сергей, смотри!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Хорошо. Теперь у нас есть бинты, антисептик и немного еды."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Ты это слышал?"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Птицы. Но нам действительно стоит уходить - скоро ночь."
    
    hide мужчина
    "{i}(Они собирают вещи и уходят в джунгли.){/i}"
    jump scene2

# --- ПРОВАЛЬНЫЙ ПУТЬ (СЦЕНА 1) ---
label scene1_fail:
    show женщина at high_right with dissolve
    alina "Я думаю, нам нужно уходить. Сейчас."
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Без воды и медикаментов будет тяжело."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Но если здесь что-то взорвётся или придут хищники…"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Ладно. Идём."
    
    hide мужчина
    "{i}(Они уходят в джунгли, не взяв ничего. Вскоре Алина спотыкается, поцарапав руку.){/i}"
    
    show мужчина at high_left with dissolve
    sergey "Жаль, что у нас нет аптечки…"
    
    scene black with fade
    narrator "Спустя час наступает ночь. Температура резко падает, а отсутствие медикаментов и воды в сочетании с открытой раной приводит к быстрому переохлаждению и потере крови. Персонажи теряют ориентацию в темноте и не могут продолжить путь. Выживание становится невозможным."
    jump game_over

# ================= СЦЕНА 2: НОЧЬ В ДЖУНГЛЯХ =================
label scene2:
    scene фото2 with dissolve
    
    show женщина at high_right with dissolve
    alina "Холодно... И так темно. Ты уверен, что нам стоит останавливаться?"
    
    
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Если пойдём дальше ночью - заблудимся или наступим на что-нибудь ядовитое."
    
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "А если это... оно придёт сюда?"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Огонь отпугнёт большинство хищников. Но если решим идти - рискуем нарваться на змей или провалиться в какую-нибудь яму."
    
    hide мужчина

    menu choice2:
        "Развести костёр и остаться на месте":
            jump scene2_main
        "Попробовать идти ночью дальше":
            jump scene2_fail

# --- ОСНОВНОЙ ПУТЬ (СЦЕНА 2) ---
label scene2_main:
    show женщина at high_right with dissolve
    alina "Вот, держи."
    
    scene фото9 with dissolve
    hide женщина
    "{i}(Пламя разгорается. Тепло расходится по промозглому воздуху. Где-то в кустах слышится недовольное рычание, но звуки отдаляются.){/i}"
    
    show мужчина at high_left with dissolve
    sergey "Видишь? Уже уходит."
    
    hide мужчина
    "{i}(Алина медленно расслабляется. Ночь проходит тревожно, но без происшествий.){/i}"
    
    scene black with dissolve
    "{i}(Проходит несколько часов...){/i}"
    jump scene3

# --- ПРОВАЛЬНЫЙ ПУТЬ (СЦЕНА 2) ---
label scene2_fail:
    show женщина at high_right with dissolve
    alina "Я не могу просто сидеть здесь и ждать, пока это что-то нас найдёт. Давай попробуем пройти ещё немного."
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Это плохая идея."
    
    hide мужчина
    "{i}(Алина делает шаг вперёд. Сергей следует за ней. Внезапно Алина вскрикивает - из-под её ноги вырывается змея.){/i}"
    
    show женщина at high_right with dissolve
    alina "Ч-что это было?!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Не двигайся!"
    
    hide мужчина
    "{i}(Укуса нет, но оба понимают, что могли бы не повезти. Рёв раздаётся гораздо ближе. Они потеряли направление.){/i}"
    
    scene black with fade
    narrator "Попытка двигаться в непроглядной темноте без освещения приводит к потере ориентации и столкновению с агрессивной фауной. Отсутствие костра лишает защиты от ночных хищников, а паника и истощение сил делают дальнейшее движение невозможным. Персонажи оказываются в изоляции и погибают."
    jump game_over

# ================= СЦЕНА 3: УТРО В ЛАГЕРЕ =================
label scene3:
    scene фото3 with dissolve
    
    show мужчина at high_left with dissolve
    sergey "Спички ещё есть, а вот воды - ни капли. Нам нужно двигаться."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "А вдруг… там, у самолёта, остались живые? Мы даже не проверили другие отсеки."
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Ночью я слышал, как корпус скрипел. Топливные баки повреждены, а солнце уже нагрело обшивку. Возвращаться туда - безумие."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Но если мы уйдём, а кто-то ждёт помощи…"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "В глубине леса должен быть ручей. Если найдём воду и выйдем к тропе - у нас будет шанс. Если вернёмся…"
    
    hide мужчина
    menu choice3:
        "Идти вглубь леса в поисках воды":
            jump scene3_main
        "Вернуться к самолёту искать выживших":
            jump scene3_fail

# --- ОСНОВНОЙ ПУТЬ (СЦЕНА 3) ---
label scene3_main:
    show женщина at high_right with dissolve
    alina "Ты прав. Нам нужна вода. Идём."
    
    hide женщина
    "{i}(Они углубляются в джунгли. Через час находят ручей. Пьют, набирают фляги.){/i}"
    
    show мужчина at high_left with dissolve
    sergey "Отлично. Теперь держимся русла. Вода выведет к людям."
    jump scene4

# --- ПРОВАЛЬНЫЙ ПУТЬ (СЦЕНА 3) ---
label scene3_fail:
    show женщина at high_right with dissolve
    alina "Я не могу их бросить. Пойдём проверим кормовой отсек."
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "(вздыхает)"
    
    hide мужчина
    "{i}(Они пробираются обратно. Чем ближе к обломкам, тем сильнее пахнет керосином. Металл раскалён.){/i}"
    
    scene black with fade
    narrator "Возвращение к месту крушения игнорирует критический риск: повреждённые топливные баки, нагретые солнцем и подтёки авиакеросина, приводят к взрыву который уничтожает всё в радиусе пятидесяти метров. Персонажи погибают на месте."
    jump game_over

# ================= СЦЕНА 4: БУРНАЯ РЕКА =================
label scene4:
    scene фото4 with dissolve
    
    show женщина at high_right with dissolve
    alina "Вертолёт! Они ищут нас! Если перебраться на тот берег, нас заметят!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Река слишком быстрая. И ширина - метров тридцать. Переплыть нереально."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Но если мы пойдём вдоль реки дальше - они улетят! Мы останемся здесь одни!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Река впадает в море. Если пойдём по берегу, выйдем к открытому пространству. Там нас увидят."
    
    hide мужчина
    menu choice4:
        "Идти вниз по течению, держаться берега":
            jump scene4_main
        "Попробовать переплыть реку":
            jump scene4_fail

# --- ОСНОВНОЙ ПУТЬ (СЦЕНА 4) ---
label scene4_main:
    show женщина at high_right with dissolve
    alina "Ладно. Ты знаешь лучше. Идём к устью."
    
    hide женщина
    "{i}(Они спускаются по безопасному склону и идут вдоль реки. Берег расширяется, деревья отступают. Вдали - светлая полоса океана.){/i}"
    
    show мужчина at high_left with dissolve
    sergey "Видишь? Выходим к пляжу. Там будет обзор на километры."
    jump scene5

# --- ПРОВАЛЬНЫЙ ПУТЬ (СЦЕНА 4) ---
label scene4_fail:
    show женщина at high_right with dissolve
    alina "Я не могу ждать! Нужно попробовать!"
    
    hide женщина
    "{i}(Алина ступает в воду. Поток сбивает с ног. Сергей прыгает следом, хватает её, но напор слишком силён.){/i}"
    
    scene black with fade
    narrator "Персонажи недооценивают скорость потока, наличие подводных камней и водоворотов. Течение мгновенно сбивает их с ног и уносит на глубину. Они теряют сознание и тонут."
    jump game_over

# ================= СЦЕНА 5: ПЛЯЖ И СИГНАЛ =================
label scene5:
    scene фото5 with dissolve
    
    show женщина at high_right with dissolve
    alina "Мы выбрались… ДА! мы выбрались!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Да. Но если корабль или самолёт пролетит мимо - нас не заметят. Нужно сделать сигнал."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Что если просто кричать? Махать руками? Они нас услышат!"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "с вертолета тебя никто не услышит. А вот контрастную надпись и дым - увидят. Сложим из камней SOS и разведём огонь."
    
    hide мужчина
    show женщина at high_right with dissolve
    alina "Это займёт время… А вдруг они уже поворачивают?"
    
    hide женщина
    show мужчина at high_left with dissolve
    sergey "Если закричим - только голос сорвём. Сигнал должен быть заметным с воздуха."
    
    hide мужчина
    menu choice5:
        "Выложить камнями «SOS» и развести дымовой костёр":
            jump scene5_main
        "Стоять у воды и кричать о помощи":
            jump scene5_fail

# --- ОСНОВНОЙ ПУТЬ (СЦЕНА 5) -> ХОРОШАЯ КОНЦОВКА ---
label scene5_main:
    show женщина at high_right with dissolve
    alina "Ты прав. Давай сделаем это правильно."
    
    hide женщина
    "{i}(Они выкладывают гигантские буквы на песке. Сергей мастерит костёр. Чёрный дым поднимается столбом.){/i}"
    scene фото6 with dissolve
    "{i}(Через двадцать минут вдали виднеется вертолет. Он приближается к ним.){/i}"
    
    show мужчина at high_left with dissolve
    sergey "Видишь? Система работает."
    
    hide мужчина
    "{i}(Они машут руками. Вертолет приближается.){/i}"
    
    scene black with dissolve
    narrator "СПАСЕНИЕ\nБлагодаря хладнокровию и правильному использованию сигнальных средств, выжившие были замечены вертолетом. Их подобрали и доставили в ближайший аэропорт.\n\nПОЗДРАВЛЯЕМ! ВЫ ПРОШЛИ ИГРУ."
    pause 5
    jump start

# --- ПРОВАЛЬНЫЙ ПУТЬ (СЦЕНА 5) ---
label scene5_fail:
    show женщина at high_right with dissolve
    alina "ЭЙ! МЫ ЗДЕСЬ! ПОМОГИТЕ!"
    
    hide женщина
    "{i}(Сергей вздыхает, но подходит. Ветер глотает крики. Волны бьют в берег. Проходит час, потом два. Солнце в зените.){/i}"
    
    scene black with fade
    narrator "Шум вертолета заглушает крики. Отсутствие визуального сигнала на фоне белого песка делает персонажей невидимыми для экипажа вертолета."
    narrator "Длительное пребывание под палящим солнцем без доступа к пресной воде приводит к критическому обезвоживанию и тепловому удару. Персонажи теряют сознание и погибают, не дождавшись помощи."
    jump game_over

# ================= ЭКРАН ПРОВАЛА =================
label game_over:
    scene black with dissolve
    play sound "heartbeat_stop.mp3" volume 0.3
    narrator "{size=32}ИГРА ОКОНЧЕНА{/size}\n\nВы приняли решение, приведшее к непоправимым последствиям в условиях выживания.\n\nНажмите для возврата в начало."
    pause 2
    jump start